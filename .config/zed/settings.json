// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ui_font_family": "CommitMono",
  "buffer_font_family": "CommitMono",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "buffer_line_height": { "custom": 1.75 },
  "cursor_blink": false,
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
      "enable_thinking": false,
      "effort": "medium",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "relative_line_numbers": "disabled",
  "icon_theme": {
    "mode": "dark",
    "light": "Warm Charmed Icons",
    "dark": "Warm Charmed Icons",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "theme": {
    "mode": "dark",
    "light": "Rosé Pine Dawn",
    "dark": "Rosé Pine Moon",
  },
  "theme_overrides": {
    "Rosé Pine Moon": {
      "editor.document_highlight.read_background": "#00000000", // Hides highlighted braces in read mode
      "editor.document_highlight.write_background": "#00000000", // Hides highlighted braces in write mode
    },
    "Rosé Pine Dawn": {
      "editor.document_highlight.read_background": "#00000000",
      "editor.document_highlight.write_background": "#00000000",
    },
  },
  "languages": {
    "HTML": {
      "format_on_save": "on",
      "formatter": "language_server",
    },
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": false,
  },
  "tab_bar": {
    "show": false,
  },
  "toolbar": {
    "quick_actions": false,
  },
  "status_bar": {
    "experimental.show": false,
  },
  "project_panel": {
    "default_width": 275,
    "hide_root": true,
    "auto_fold_dirs": false,
    "starts_open": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 200,
  },
  "file_finder": {
    "modal_max_width": "small",
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
  },
  "indent_guides": {
    "enabled": false,
  },
  "auto_indent_on_paste": false,
  "show_edit_predictions": false,
  "show_completions_on_input": false,
  "drag_and_drop_selection": {
    "enabled": false,
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "none",
  "show_whitespaces": "none",
  "tab_size": 2,
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "empty_tab",
}
